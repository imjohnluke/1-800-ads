---
import PageLayout from '../layouts/PageLayout.astro'
import PricingSlider from '../components/1800-ads/PricingSlider.astro'
import WorkGallery from '../components/1800-ads/WorkGallery.astro'
import ClosingSection from '../components/1800-ads/ClosingSection.astro'
import TestimonialsSection from '../components/1800-ads/TestimonialsSection.astro'
import OfferSection from '../components/1800-ads/OfferSection.astro'
import FlexibilitySection from '../components/1800-ads/FlexibilitySection.astro'
import ScrollStatement from '../components/1800-ads/ScrollStatement.astro'
import FaqSection from '../components/1800-ads/FaqSection.astro'
import Footer1800Ads from '../components/1800-ads/Footer1800Ads.astro'
import { ADS_INCLUDED } from '../data/1800-ads-pricing'
import { webPageSchema } from '../lib/schema'
import { SITE_URL } from '../lib/site'

const tickerCol1 = [
  '/images/1-800-ads/ad-1.png',
  '/images/1-800-ads/ad-2.png',
  '/images/1-800-ads/ad-3.png',
  '/images/1-800-ads/ad-4.png',
  '/images/1-800-ads/ad-5.png',
]

const tickerCol2 = [
  '/images/1-800-ads/ad-6.png',
  '/images/1-800-ads/ad-3.png',
  '/images/1-800-ads/ad-2.png',
  '/images/1-800-ads/ad-5.png',
  '/images/1-800-ads/ad-4.png',
]

const brandLogos = [
  { src: '/images/managed-services/Huel.png', alt: 'Huel' },
  { src: '/images/managed-services/MUDWTR.png', alt: 'MUDWTR' },
  { src: '/images/managed-services/Brez logo 1.png', alt: 'Brez' },
  { src: '/images/managed-services/danone.png', alt: 'Danone' },
  { src: '/images/managed-services/FERMAT 1.png', alt: 'FERMAT' },
  { src: '/images/managed-services/Obvi.png', alt: 'Obvi' },
  { src: '/images/managed-services/SavageXFenty.png', alt: 'Savage X Fenty' },
  { src: '/images/managed-services/Magic Mind 1.png', alt: 'Magic Mind' },
  { src: '/images/managed-services/Black Rifle Coffee Company.png', alt: 'Black Rifle Coffee' },
]

const schemas = [
  webPageSchema({
    name: '1-800 Ads — Static Ad Creatives On Demand',
    description:
      'Order professional static ad creatives à la carte. No subscription — concept, design, and delivery in under 24 hours.',
    url: `${SITE_URL}/`,
  }),
]
---

<PageLayout
  title="1-800 Ads — Static Ad Creatives On Demand"
  description="Order professional static ad creatives à la carte. No subscription — concept, design, and delivery in under 24 hours."
>
  <Fragment slot="head">
    {schemas.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:ital,wght@0,400;0,500;0,600;0,700;0,800;1,700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="ea-page">
    <section class="ea-hero" aria-labelledby="eighteen-hero-heading">
      <div class="ea-wrap ea-hero-text">
        <div class="ea-hero-copy">
          <h1 id="eighteen-hero-heading" class="ea-h-xl">
            Your on&#8209;demand static ad<br class="ea-br-mobile" />
            <span class="ea-grad-text">creative partner</span>
          </h1>
          <div class="ea-hero-right">
            <p class="ea-body-lg">
              Our one-time purchase option for brands that want fresh static ads without a subscription.
              We concept, design, and deliver — <b style="color: var(--ea-ink);">pay per order, ready in under 24 hours.</b>
            </p>
          </div>
          <div class="ea-hero-ctas">
            <a class="ea-btn ea-btn-soft" href="#order">
              Order ads
              <svg class="ea-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6" /></svg>
            </a>
            <a class="ea-btn ea-btn-outline" href="#work">See examples</a>
          </div>
          <div class="ea-hero-meta">
            <span>À la carte</span>
            <span class="ea-dot"></span>
            <span>Under 24 hour delivery</span>
          </div>
        </div>

        <div class="ea-hero-visual" aria-hidden="true">
          <div class="ea-ticker-col">
            <div class="ea-ticker-mask">
              <div class="ea-ticker-track ea-ticker-track--up">
                {
                  [...tickerCol1, ...tickerCol1].map((src) => (
                    <div class="ea-ticker-card">
                      <img src={src} alt="" loading="lazy" width="220" height="275" />
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
          <div class="ea-ticker-col ea-ticker-col--offset">
            <div class="ea-ticker-mask">
              <div class="ea-ticker-track ea-ticker-track--down">
                {
                  [...tickerCol2, ...tickerCol2].map((src) => (
                    <div class="ea-ticker-card">
                      <img src={src} alt="" loading="lazy" width="220" height="275" />
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="ea-logobar">
      <div class="ea-wrap">
        <div class="ea-logobar-label">Trusted by 25,000+ brands</div>
        <div class="ea-logo-mask">
          <div class="ea-logo-track">
            <div class="ea-logo-row">
              {
                brandLogos.map((logo) => (
                  <div class="ea-logo">
                    <img src={logo.src} alt={logo.alt} />
                  </div>
                ))
              }
            </div>
            <div class="ea-logo-row" aria-hidden="true">
              {
                brandLogos.map((logo) => (
                  <div class="ea-logo">
                    <img src={logo.src} alt="" />
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>

    <ScrollStatement />
  </div>

  <OfferSection />

  <FlexibilitySection />

  <WorkGallery />

  <section class="ea-page ea-pricing-section" id="order" aria-labelledby="ea-pricing-heading">
    <div class="ea-wrap ea-pricing-split">
      <div class="ea-pricing-copy ea-hero-copy">
        <span class="ea-eyebrow">Pricing</span>
        <h2 id="ea-pricing-heading" class="ea-h-xl ea-pricing-title">
          Pay per batch.<br />
          <span class="ea-grad-text">Less per ad.</span>
        </h2>
        <div class="ea-hero-right">
          <p class="ea-body-lg">
            Choose your quantity, submit your brief and get high converting ads in days, not weeks.
          </p>
        </div>
        <ul class="ea-pricing-benefits">
          {
            ADS_INCLUDED.map((item) => (
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path
                    d="M20 6 9 17l-5-5"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
                {item}
              </li>
            ))
          }
        </ul>
      </div>
      <div class="ea-pricing-card-col">
        <PricingSlider />
      </div>
    </div>
  </section>

  <ClosingSection />

  <TestimonialsSection />

  <section class="ea-page ea-final-cta" id="ea-cta" aria-labelledby="ea-cta-heading">
    <div class="ea-wrap">
      <div class="ea-cta-card">
        <span class="ea-eyebrow ea-eyebrow-light">Get started</span>
        <h2 id="ea-cta-heading" class="ea-h-xl ea-cta-title">
          Like what you see?<br />Order your <span class="ea-grad-text">first batch.</span>
        </h2>
        <p class="ea-cta-sub">
          Pick your quantity, send a brief, and get fresh static ads in under 24 hours — no subscription required.
        </p>
        <a class="ea-btn ea-btn-grad ea-cta-btn" href="#order">
          Order ads now
          <svg
            class="ea-arrow"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#fff"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"><path d="m9 18 6-6-6-6"></path></svg>
        </a>
      </div>
    </div>
  </section>

  <FaqSection />

  <Footer1800Ads slot="footer" />
</PageLayout>

<style>
  .ea-page {
    --ea-bg: #ffffff;
    --ea-ink: #11110f;
    --ea-muted: #6b6677;
    --ea-line: #e2dbf0;
    --ea-surface: #f5f0ff;
    --ea-dark: #11110f;
    --ea-accent: #ff6b2e;
    --ea-grad: linear-gradient(90deg, #ff8a3d 0%, #ff6b2e 22%, #e84b6f 55%, #9c42e0 80%, #7b3fe4 100%);
    --ea-font-display: 'Inter Tight', 'Plus Jakarta Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    --ea-font-sans: 'Inter', 'DM Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    --ea-font-mono: 'JetBrains Mono', ui-monospace, Menlo, monospace;
    --ea-radius-lg: 18px;
    --ea-pad: clamp(20px, 3vw, 28px);
    --ea-maxw: 1232px;

    font-family: var(--ea-font-sans);
    color: var(--ea-ink);
    background: var(--ea-bg);
    -webkit-font-smoothing: antialiased;
  }

  .ea-page *,
  .ea-page *::before,
  .ea-page *::after {
    box-sizing: border-box;
  }

  .ea-page img {
    max-width: 100%;
    display: block;
  }

  .ea-page a {
    color: inherit;
    text-decoration: none;
  }

  .ea-br-mobile {
    display: none;
  }

  @media (max-width: 780px) {
    .ea-br-mobile {
      display: block;
    }

    .ea-hero .ea-h-xl {
      font-size: clamp(34px, 9.5vw, 42px);
    }
  }

  .ea-wrap {
    max-width: var(--ea-maxw);
    margin: 0 auto;
    padding: 0 var(--ea-pad);
  }

  .ea-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--ea-font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ea-accent);
  }

  .ea-accent-dot::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ea-accent);
    flex: 0 0 6px;
  }

  .ea-h-xl {
    font-family: var(--ea-font-display);
    font-weight: 800;
    font-size: clamp(42px, 5.6vw, 68px);
    line-height: 0.93;
    letter-spacing: -0.036em;
    word-spacing: 0.045em;
    margin: 0;
    max-width: 600px;
    text-wrap: balance;
    color: var(--ea-ink);
  }

  .ea-grad-text {
    background: var(--ea-grad);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .ea-body-lg {
    font-size: clamp(16px, 1.45vw, 18px);
    line-height: 1.48;
    letter-spacing: -0.02em;
    color: var(--ea-muted);
    margin: 0;
    max-width: 42rem;
  }

  .ea-btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    min-height: 46px;
    padding: 12px 22px;
    border-radius: 999px;
    font-family: var(--ea-font-display);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: -0.005em;
    transition:
      transform 180ms ease,
      background 180ms ease,
      opacity 180ms ease;
    white-space: nowrap;
    cursor: pointer;
  }

  .ea-btn:hover {
    transform: translateY(-1px);
  }

  .ea-btn-soft {
    border: 0;
    background: var(--ea-surface);
    color: var(--ea-ink);
    -webkit-text-fill-color: var(--ea-ink);
  }

  .ea-btn-soft:hover {
    background: #ece5fa;
  }

  .ea-btn-outline {
    border: 1.5px solid #d8c9f5;
    background: transparent;
    color: var(--ea-ink);
    -webkit-text-fill-color: var(--ea-ink);
  }

  .ea-btn-outline:hover {
    background: rgba(123, 63, 228, 0.06);
    border-color: #c9b8f0;
  }

  .ea-btn-grad {
    background: var(--ea-grad);
    color: #fff;
    -webkit-text-fill-color: #fff;
    box-shadow: 0 8px 24px -8px rgba(232, 75, 111, 0.4);
  }

  .ea-btn-grad:hover {
    filter: brightness(1.04);
  }

  .ea-arrow {
    display: inline-block;
    vertical-align: middle;
  }

  .ea-hero {
    padding: clamp(60px, 8vw, 100px) 0 clamp(52px, 7vw, 80px);
  }

  .ea-hero-text {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.95fr);
    gap: clamp(44px, 7vw, 88px);
    align-items: center;
  }

  @media (max-width: 780px) {
    .ea-hero-text {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  .ea-hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .ea-hero-right {
    display: flex;
    flex-direction: column;
    gap: 17px;
    padding-top: 16px;
    max-width: 620px;
  }

  .ea-hero-ctas {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  .ea-hero-meta {
    display: flex;
    gap: 14px;
    align-items: center;
    margin-top: 16px;
    font-family: var(--ea-font-mono);
    font-size: 10px;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #8a8398;
  }

  .ea-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: currentColor;
  }

  .ea-hero-visual {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    height: min(520px, 62vw);
    min-height: 320px;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .ea-hero-visual {
      height: 680px;
      min-height: 680px;
      gap: 0.625rem;
    }
  }

  .ea-hero-visual::before {
    content: '';
    position: absolute;
    inset: 10% 8%;
    background: radial-gradient(circle, rgba(103, 59, 236, 0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .ea-ticker-col {
    flex: 1;
    max-width: 220px;
    height: 100%;
    position: relative;
    z-index: 1;
  }

  @media (min-width: 1024px) {
    .ea-ticker-col {
      max-width: 226px;
    }

    .ea-ticker-col--offset {
      margin-top: -3rem;
    }
  }

  .ea-ticker-col--offset {
    margin-top: -2rem;
  }

  .ea-ticker-mask {
    height: 100%;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      #000 14%,
      #000 86%,
      transparent 100%
    );
    mask-image: linear-gradient(to bottom, transparent 0%, #000 14%, #000 86%, transparent 100%);
  }

  .ea-ticker-track {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 0.5rem;
    will-change: transform;
  }

  .ea-ticker-track--up {
    animation: ea-ticker-up 30s linear infinite;
  }

  .ea-ticker-track--down {
    animation: ea-ticker-down 34s linear infinite;
  }

  .ea-ticker-card {
    aspect-ratio: 4 / 5;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    border: 1px solid var(--ea-line);
    background: #fff;
    box-shadow:
      0 4px 16px rgba(17, 24, 39, 0.06),
      0 1px 3px rgba(17, 24, 39, 0.04);
  }

  .ea-ticker-card img {
    display: block;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: center;
  }

  @keyframes ea-ticker-up {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(-50%);
    }
  }

  @keyframes ea-ticker-down {
    0% {
      transform: translateY(-50%);
    }
    100% {
      transform: translateY(0);
    }
  }

  .ea-logobar {
    padding: 22px 0;
    background: var(--ea-bg);
  }

  .ea-logobar-label {
    font-family: var(--ea-font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ea-muted);
    text-align: center;
    margin-bottom: 16px;
  }

  .ea-logo-mask {
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }

  .ea-logo-track {
    display: flex;
    gap: 56px;
    align-items: center;
    width: max-content;
    animation: ea-marquee 40s linear infinite;
  }

  .ea-logo-row {
    display: flex;
    gap: 56px;
    align-items: center;
  }

  .ea-logo {
    height: 36px;
    display: flex;
    align-items: center;
  }

  .ea-logo img {
    height: 100%;
    width: auto;
    max-width: none;
    object-fit: contain;
    opacity: 0.62;
    filter: grayscale(0.2);
  }

  @keyframes ea-marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 780px) {
    .ea-hero-copy {
      align-items: center;
      text-align: center;
    }

    .ea-hero-right,
    .ea-h-xl {
      max-width: none;
    }

    .ea-hero-ctas,
    .ea-hero-meta {
      justify-content: center;
    }

    .ea-hero-visual {
      height: 400px;
      min-height: 400px;
      gap: 0.5rem;
      margin-inline: calc(-1 * var(--ea-pad));
      width: calc(100% + 2 * var(--ea-pad));
    }

    .ea-ticker-col {
      max-width: none;
      flex: 1 1 0;
    }

    .ea-ticker-track {
      gap: 0.5rem;
      padding: 0.35rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ea-ticker-track--up,
    .ea-ticker-track--down,
    .ea-logo-track {
      animation: none;
    }
  }

  .ea-pricing-section {
    padding: clamp(60px, 8vw, 96px) 0;
    background: radial-gradient(ellipse at 50% 30%, rgba(140, 50, 210, 0.45) 0%, transparent 65%), #1a0830;
  }

  @media (min-width: 901px) {
    .ea-pricing-section {
      padding: clamp(100px, 12vw, 148px) 0;
    }
  }

  .ea-pricing-section .ea-h-xl {
    color: #fff;
  }

  .ea-pricing-section .ea-body-lg {
    color: rgba(255, 255, 255, 0.55);
  }

  .ea-pricing-section .ea-pricing-benefits li {
    color: rgba(255, 255, 255, 0.62);
  }

  .ea-pricing-section .ea-pricing-benefits svg {
    color: #c9a8ff;
  }

  .ea-wrap.ea-pricing-split {
    max-width: 1080px;
  }

  .ea-pricing-split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(380px, 1fr);
    gap: clamp(20px, 2.5vw, 32px);
    align-items: center;
  }

  @media (max-width: 900px) {
    .ea-pricing-split {
      grid-template-columns: 1fr;
      gap: 2rem;
      align-items: stretch;
    }

    .ea-pricing-copy {
      display: contents;
    }

    .ea-pricing-copy .ea-eyebrow {
      order: 1;
      justify-self: center;
    }

    .ea-pricing-copy .ea-pricing-title {
      order: 2;
      justify-self: center;
      text-align: center;
      margin-inline: auto;
      margin-top: -1.5rem;
      margin-bottom: 0;
    }

    .ea-pricing-copy .ea-hero-right {
      order: 3;
      justify-self: center;
      text-align: center;
      margin-top: -1.5rem;
      padding-top: 0;
      max-width: 28rem;
    }

    .ea-pricing-card-col {
      order: 4;
    }
  }

  .ea-pricing-copy {
    max-width: none;
  }

  .ea-pricing-title {
    margin-top: 6px;
    font-size: clamp(36px, 4.8vw, 56px);
    max-width: 11ch;
  }

  .ea-pricing-copy .ea-hero-right {
    padding-top: 12px;
    max-width: 22rem;
  }

  .ea-pricing-benefits {
    list-style: none;
    margin: 28px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem 1.5rem;
    max-width: 36rem;
  }

  @media (max-width: 900px) {
    .ea-pricing-benefits {
      display: none;
    }
  }

  .ea-pricing-benefits li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: 0.9rem;
    line-height: 1.45;
    color: var(--ea-muted);
  }

  .ea-pricing-benefits svg {
    flex-shrink: 0;
    margin-top: 0.15rem;
    color: #673bec;
  }

  .ea-pricing-card-col {
    min-width: 0;
  }

  .ea-final-cta {
    padding: clamp(40px, 5vw, 64px) 0 clamp(48px, 7vw, 88px);
  }

  .ea-eyebrow-light {
    color: rgba(248, 245, 238, 0.62);
  }

  .ea-cta-card {
    background: radial-gradient(ellipse at 50% 30%, rgba(140, 50, 210, 0.45) 0%, transparent 65%), #1a0830;
    border-radius: var(--ea-radius-lg);
    padding: clamp(52px, 8vw, 108px) clamp(32px, 6vw, 80px);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }

  .ea-cta-title {
    color: #fff;
    max-width: none;
    line-height: 1.05;
  }

  .ea-cta-sub {
    margin: 0;
