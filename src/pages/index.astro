---
export const prerender = false

import PageLayout from '../layouts/PageLayout.astro'
import PricingSlider from '../components/1800-ads/PricingSlider.astro'
import WorkGallery from '../components/1800-ads/WorkGallery.astro'
import ClosingSection from '../components/1800-ads/ClosingSection.astro'
import TestimonialsSection from '../components/1800-ads/TestimonialsSection.astro'
import OfferSection from '../components/1800-ads/OfferSection.astro'
import FlexibilitySection from '../components/1800-ads/FlexibilitySection.astro'
import ScrollStatement from '../components/1800-ads/ScrollStatement.astro'
import FaqSection from '../components/1800-ads/FaqSection.astro'
import Footer1800Ads from '../components/1800-ads/Footer1800Ads.astro'
import { ADS_INCLUDED } from '../data/1800-ads-pricing'
import { webPageSchema } from '../lib/schema'
import { SITE_URL } from '../lib/site'

const tickerCol1 = [
  '/images/1-800-ads/mad-coffee-faster.png',
  '/images/1-800-ads/inessa-wellness-bundle.png',
  '/images/1-800-ads/mad-coffee-compostable.png',
  '/images/1-800-ads/ad-1.png',
  '/images/1-800-ads/ad-3.png',
  '/images/1-800-ads/ad-5.png',
]

const tickerCol2 = [
  '/images/1-800-ads/inessa-wellness-bundle.png',
  '/images/1-800-ads/mad-coffee-compostable.png',
  '/images/1-800-ads/mad-coffee-faster.png',
  '/images/1-800-ads/ad-6.png',
  '/images/1-800-ads/ad-2.png',
  '/images/1-800-ads/ad-4.png',
]

const brandLogos = [
  { src: '/images/trusted-by/miss-grass.png', alt: 'Miss Grass' },
  { src: '/images/trusted-by/mad-coffee.png', alt: 'MAD Coffee' },
  { src: '/images/trusted-by/portal.png', alt: 'Portal' },
  { src: '/images/trusted-by/inessa.png', alt: 'Inessa' },
]

const schemas = [
  webPageSchema({
    name: '1-800 Ads — Static Ad Creatives On Demand',
    description:
      'Order professional static ad creatives à la carte. No subscription — concept, design, and delivery in under 24 hours.',
    url: `${SITE_URL}/`,
  }),
]
---

<PageLayout
  title="1-800 Ads — Static Ad Creatives On Demand"
  description="Order professional static ad creatives à la carte. No subscription — concept, design, and delivery in under 24 hours."
>
  <Fragment slot="head">
    {schemas.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
  </Fragment>

  <div class="ea-page">
    <section class="ea-hero" data-nav-theme="red" aria-labelledby="eighteen-hero-heading">
      <div class="ea-wrap ea-hero-text">
        <div class="ea-hero-copy">
          <h1 id="eighteen-hero-heading" class="ea-h-xl">
            Your on&#8209;demand static ad<br class="ea-br-mobile" />
            <span class="ea-grad-text">creative partner</span>
          </h1>
          <div class="ea-hero-right">
            <p class="ea-body-lg">
              Our one-time purchase option for brands that want fresh static ads without a subscription.
              We concept, design, and deliver — <b>pay per order, ready in under 24 hours.</b>
            </p>
          </div>
          <div class="ea-hero-ctas">
            <a class="ea-btn ea-btn-soft" href="#order">
              Order ads
              <svg class="ea-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6" /></svg>
            </a>
            <a class="ea-btn ea-btn-outline" href="#work">See examples</a>
          </div>
          <div class="ea-hero-meta">
            <span>À la carte</span>
            <span class="ea-dot"></span>
            <span>Under 24 hour delivery</span>
          </div>
        </div>

        <div class="ea-hero-visual" aria-hidden="true">
          <div class="ea-ticker-col">
            <div class="ea-ticker-mask">
              <div class="ea-ticker-track ea-ticker-track--up">
                {
                  [...tickerCol1, ...tickerCol1].map((src) => (
                    <div class="ea-ticker-card">
                      <img src={src} alt="" loading="lazy" width="220" height="275" />
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
          <div class="ea-ticker-col ea-ticker-col--offset">
            <div class="ea-ticker-mask">
              <div class="ea-ticker-track ea-ticker-track--down">
                {
                  [...tickerCol2, ...tickerCol2].map((src) => (
                    <div class="ea-ticker-card">
                      <img src={src} alt="" loading="lazy" width="220" height="275" />
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="ea-logobar" data-nav-theme="cream">
      <div class="ea-wrap">
        <div class="ea-logobar-label">Trusted by brands</div>
        <div class="ea-logo-row">
          {
            brandLogos.map((logo) => (
              <div class="ea-logo">
                <img src={logo.src} alt={logo.alt} loading="lazy" decoding="async" />
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <ScrollStatement />
  </div>

  <OfferSection />

  <FlexibilitySection />

  <WorkGallery />

  <section class="ea-page ea-pricing-section" id="order" data-nav-theme="cream" aria-labelledby="ea-pricing-heading">
    <div class="ea-wrap ea-pricing-split">
      <div class="ea-pricing-copy ea-hero-copy">
        <span class="ea-eyebrow">Pricing</span>
        <h2 id="ea-pricing-heading" class="ea-h-xl ea-pricing-title">
          Pay per batch.<br />
          <span class="ea-grad-text">Less per ad.</span>
        </h2>
        <div class="ea-hero-right">
          <p class="ea-body-lg">
            Choose your quantity, submit your brief and get high converting ads in days, not weeks.
          </p>
        </div>
        <ul class="ea-pricing-benefits">
          {
            ADS_INCLUDED.map((item) => (
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path
                    d="M20 6 9 17l-5-5"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
                {item}
              </li>
            ))
          }
        </ul>
      </div>
      <div class="ea-pricing-card-col">
        <PricingSlider />
      </div>
    </div>
  </section>

  <ClosingSection />

  <TestimonialsSection />

  <section class="ea-page ea-final-cta" id="ea-cta" data-nav-theme="cream" aria-labelledby="ea-cta-heading">
    <div class="ea-wrap">
      <div class="ea-cta-card">
        <span class="ea-eyebrow ea-eyebrow-light">Get started</span>
        <h2 id="ea-cta-heading" class="ea-h-xl ea-cta-title">
          Like what you see?<br />Order your <span class="ea-grad-text">first batch.</span>
        </h2>
        <p class="ea-cta-sub">
          Pick your quantity, send a brief, and get fresh static ads in under 24 hours — no subscription required.
        </p>
        <a class="ea-btn ea-btn-grad ea-cta-btn" href="#order">
          Order ads now
          <svg
            class="ea-arrow"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"><path d="m9 18 6-6-6-6"></path></svg>
        </a>
      </div>
    </div>
  </section>

  <FaqSection />

  <Footer1800Ads slot="footer" />
</PageLayout>

<style>
  .ea-page {
    --ea-radius-lg: 18px;
    --ea-pad: clamp(20px, 3vw, 28px);
    --ea-maxw: 1232px;

    font-family: var(--ea-font-sans);
    color: var(--ea-ink);
    background: var(--ea-bg);
  }

  .ea-page *,
  .ea-page *::before,
  .ea-page *::after {
    box-sizing: border-box;
  }

  .ea-page img {
    max-width: 100%;
    display: block;
  }

  .ea-page a {
    color: inherit;
    text-decoration: none;
  }

  .ea-br-mobile {
    display: none;
  }

  @media (max-width: 780px) {
    .ea-br-mobile {
      display: block;
    }

    .ea-hero .ea-h-xl {
      font-size: clamp(34px, 9.5vw, 42px);
    }
  }

  .ea-wrap {
    max-width: var(--ea-maxw);
    margin: 0 auto;
    padding: 0 var(--ea-pad);
  }

  .ea-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--ea-font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ea-accent);
  }

  .ea-accent-dot::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ea-accent);
    flex: 0 0 6px;
  }

  .ea-h-xl {
    font-family: var(--ea-font-display);
    font-weight: 400;
    font-size: clamp(42px, 5.6vw, 68px);
    line-height: 0.98;
    letter-spacing: -0.01em;
    margin: 0;
    max-width: 600px;
    text-wrap: balance;
    color: var(--ea-ink);
  }

  .ea-grad-text {
    color: var(--brand-red);
    -webkit-text-fill-color: var(--brand-red);
  }

  .ea-body-lg {
    font-size: clamp(16px, 1.45vw, 18px);
    line-height: 1.48;
    letter-spacing: -0.02em;
    color: var(--ea-muted);
    margin: 0;
    max-width: 42rem;
  }

  .ea-hero {
    padding: calc(clamp(60px, 8vw, 100px) + var(--site-header-height, 64px)) 0
      clamp(52px, 7vw, 80px);
    background: var(--brand-red);
    color: var(--brand-white);
  }

  .ea-hero .ea-h-xl {
    color: var(--brand-white);
  }

  .ea-hero .ea-grad-text {
    color: var(--brand-yellow);
    -webkit-text-fill-color: var(--brand-yellow);
  }

  .ea-hero .ea-body-lg {
    color: var(--brand-muted-on-red);
  }

  .ea-hero .ea-body-lg b {
    color: var(--brand-white);
    font-weight: 700;
  }

  .ea-hero .ea-btn-soft {
    background: var(--brand-white);
    color: var(--brand-ink);
    -webkit-text-fill-color: var(--brand-ink);
  }

  .ea-hero .ea-btn-soft:hover {
    background: var(--brand-white);
    color: var(--brand-ink);
    -webkit-text-fill-color: var(--brand-ink);
  }

  .ea-hero .ea-btn-outline {
    border: 2px solid rgba(255, 255, 255, 0.65);
    color: var(--brand-white);
    -webkit-text-fill-color: var(--brand-white);
  }

  .ea-hero .ea-btn-outline:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: var(--brand-white);
  }

  .ea-hero .ea-hero-meta {
    color: rgba(255, 255, 255, 0.72);
  }

  .ea-hero .ea-hero-visual::before {
    background: radial-gradient(circle, rgba(255, 255, 255, 0.08) 0%, transparent 70%);
  }

  .ea-btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    min-height: 46px;
    padding: 12px 22px;
    border-radius: 999px;
    font-family: var(--ea-font-sans);
    font-weight: 600;
    font-size: 15px;
    letter-spacing: -0.005em;
    transition:
      transform 180ms ease,
      background 180ms ease,
      opacity 180ms ease;
    white-space: nowrap;
    cursor: pointer;
  }

  .ea-btn:hover {
    transform: translateY(-1px);
  }

  .ea-btn-soft {
    border: 0;
    background: var(--brand-yellow);
    color: var(--brand-ink);
    -webkit-text-fill-color: var(--brand-ink);
  }

  .ea-btn-soft:hover {
    background: var(--brand-yellow);
    color: var(--brand-ink);
    -webkit-text-fill-color: var(--brand-ink);
    transform: none;
  }

  .ea-btn-outline {
    border: 2px solid rgba(42, 8, 16, 0.28);
    background: transparent;
    color: var(--brand-ink);
    -webkit-text-fill-color: var(--brand-ink);
  }

  .ea-btn-outline:hover {
    background: rgba(42, 8, 16, 0.05);
    border-color: rgba(42, 8, 16, 0.45);
  }

  .ea-btn-grad {
    background: var(--brand-yellow);
    color: var(--brand-ink);
    -webkit-text-fill-color: var(--brand-ink);
    box-shadow: 0 8px 24px -8px rgba(0, 0, 0, 0.35);
  }

  .ea-btn-grad:hover {
    filter: brightness(1.05);
  }

  .ea-btn-soft .ea-arrow,
  .ea-btn-soft .ea-arrow path {
    color: var(--brand-ink);
    stroke: var(--brand-ink);
  }

  .ea-arrow {
    display: inline-block;
    vertical-align: middle;
    flex-shrink: 0;
  }

  .ea-hero-text {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.95fr);
    gap: clamp(44px, 7vw, 88px);
    align-items: center;
  }

  @media (max-width: 780px) {
    .ea-hero-text {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  .ea-hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .ea-hero-right {
    display: flex;
    flex-direction: column;
    gap: 17px;
    padding-top: 16px;
    max-width: 620px;
  }

  .ea-hero-ctas {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  .ea-hero-meta {
    display: flex;
    gap: 14px;
    align-items: center;
    margin-top: 16px;
    font-family: var(--ea-font-mono);
    font-size: 10px;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .ea-pricing-copy .ea-hero-meta,
  .ea-pricing-section .ea-hero-meta {
    color: var(--brand-muted);
  }

  .ea-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: currentColor;
  }

  .ea-hero-visual {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    height: min(520px, 62vw);
    min-height: 320px;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .ea-hero-visual {
      height: 680px;
      min-height: 680px;
      gap: 0.625rem;
    }
  }

  .ea-hero-visual::before {
    content: '';
    position: absolute;
    inset: 10% 8%;
    pointer-events: none;
  }

  .ea-ticker-col {
    flex: 1;
    max-width: 220px;
    height: 100%;
    position: relative;
    z-index: 1;
  }

  @media (min-width: 1024px) {
    .ea-ticker-col {
      max-width: 226px;
    }

    .ea-ticker-col--offset {
      margin-top: -3rem;
    }
  }

  .ea-ticker-col--offset {
    margin-top: -2rem;
  }

  .ea-ticker-mask {
    height: 100%;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      #000 14%,
      #000 86%,
      transparent 100%
    );
    mask-image: linear-gradient(to bottom, transparent 0%, #000 14%, #000 86%, transparent 100%);
  }

  .ea-ticker-track {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 0.5rem;
    will-change: transform;
  }

  .ea-ticker-track--up {
    animation: ea-ticker-up 30s linear infinite;
  }

  .ea-ticker-track--down {
    animation: ea-ticker-down 34s linear infinite;
  }

  .ea-ticker-card {
    aspect-ratio: 4 / 5;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    border: 1px solid var(--ea-line);
    background: #fff;
    box-shadow:
      0 4px 16px rgba(17, 24, 39, 0.06),
      0 1px 3px rgba(17, 24, 39, 0.04);
  }

  .ea-ticker-card img {
    display: block;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: center;
  }

  @keyframes ea-ticker-up {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(-50%);
    }
  }

  @keyframes ea-ticker-down {
    0% {
      transform: translateY(-50%);
    }
    100% {
      transform: translateY(0);
    }
  }

  .ea-logobar {
    padding: 22px 0;
    background: var(--brand-cream);
    border-top: 1px solid rgba(42, 8, 16, 0.08);
    border-bottom: 1px solid rgba(42, 8, 16, 0.08);
  }

  .ea-logobar-label {
    font-family: var(--ea-font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brand-muted);
    text-align: center;
    margin-bottom: 16px;
  }

  .ea-logo-row {
    display: flex;
    gap: clamp(28px, 5vw, 56px);
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
  }

  .ea-logo {
    height: 36px;
    display: flex;
    align-items: center;
  }

  .ea-logo img {
    height: 100%;
    width: auto;
    max-width: none;
    object-fit: contain;
    opacity: 0.82;
    filter: invert(1);
    mix-blend-mode: multiply;
  }

  @media (max-width: 540px) {
    .ea-logobar {
      padding: 16px 0;
    }

    .ea-logobar-label {
      margin-bottom: 10px;
    }

    .ea-logo-row {
      gap: 12px 18px;
    }

    .ea-logo {
      height: 22px;
      max-width: 38vw;
    }

    .ea-logo img {
      max-width: 100%;
    }
  }

  @media (max-width: 780px) {
    .ea-hero-copy {
      align-items: center;
      text-align: center;
    }

    .ea-hero-right,
    .ea-h-xl {
      max-width: none;
    }

    .ea-hero-ctas,
    .ea-hero-meta {
      justify-content: center;
    }

    .ea-hero-visual {
      height: 400px;
      min-height: 400px;
      gap: 0.5rem;
      margin-inline: calc(-1 * var(--ea-pad));
      width: calc(100% + 2 * var(--ea-pad));
    }

    .ea-ticker-col {
      max-width: none;
      flex: 1 1 0;
    }

    .ea-ticker-track {
      gap: 0.5rem;
      padding: 0.35rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ea-ticker-track--up,
    .ea-ticker-track--down,
    .ea-logo-track {
      animation: none;
    }
  }

  .ea-pricing-section {
    padding: clamp(60px, 8vw, 96px) 0;
    background: var(--brand-cream);
  }

  @media (min-width: 901px) {
    .ea-pricing-section {
      padding: clamp(100px, 12vw, 148px) 0;
    }
  }

  .ea-wrap.ea-pricing-split {
    max-width: 1080px;
  }

  .ea-pricing-split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(380px, 1fr);
    gap: clamp(20px, 2.5vw, 32px);
    align-items: center;
  }

  @media (max-width: 900px) {
    .ea-pricing-split {
      grid-template-columns: 1fr;
      gap: 2rem;
      align-items: stretch;
    }

    .ea-pricing-copy {
      display: contents;
    }

    .ea-pricing-copy .ea-eyebrow {
      order: 1;
      justify-self: center;
    }

    .ea-pricing-copy .ea-pricing-title {
      order: 2;
      justify-self: center;
      text-align: center;
      margin-inline: auto;
      margin-top: 0.5rem;
      margin-bottom: 0;
    }

    .ea-pricing-copy .ea-hero-right {
      order: 3;
      justify-self: center;
      text-align: center;
      margin-top: -1.5rem;
      padding-top: 0;
      max-width: 28rem;
    }

    .ea-pricing-card-col {
      order: 4;
    }
  }

  .ea-pricing-copy {
    max-width: none;
  }

  .ea-pricing-title {
    margin-top: 14px;
    font-size: clamp(36px, 4.8vw, 56px);
    max-width: 11ch;
  }

  .ea-pricing-copy .ea-hero-right {
    padding-top: 12px;
    max-width: 22rem;
  }

  .ea-pricing-benefits {
    list-style: none;
    margin: 28px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem 1.5rem;
    max-width: 36rem;
  }

  @media (max-width: 900px) {
    .ea-pricing-benefits {
      display: none;
    }
  }

  .ea-pricing-benefits li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: 0.9rem;
    line-height: 1.45;
    color: var(--ea-muted);
  }

  .ea-pricing-benefits svg {
    flex-shrink: 0;
    margin-top: 0.15rem;
    color: var(--brand-red);
  }

  .ea-pricing-card-col {
    min-width: 0;
  }

  .ea-final-cta {
    padding: clamp(40px, 5vw, 64px) 0 clamp(48px, 7vw, 88px);
  }

  .ea-eyebrow-light {
    color: rgba(248, 245, 238, 0.62);
  }

  .ea-cta-card {
    background: var(--brand-red);
    border: 2px solid rgba(255, 255, 255, 0.14);
    border-radius: var(--ea-radius-lg);
    padding: clamp(52px, 8vw, 108px) clamp(32px, 6vw, 80px);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }

  .ea-cta-card .ea-eyebrow-light {
    color: var(--brand-yellow);
  }

  .ea-cta-title {
    color: var(--brand-white);
    max-width: none;
    line-height: 1.05;
  }

  .ea-cta-card .ea-grad-text {
    color: var(--brand-yellow);
    -webkit-text-fill-color: var(--brand-yellow);
  }

  .ea-cta-sub {
