---
import PageLayout from '../layouts/PageLayout.astro'
import Container from '../components/ui/Container.astro'
---

<PageLayout
  title="Order Confirmed"
  description="Your 1-800 Ads order is confirmed. We'll send your brief intake next."
  noIndex={true}
>
  <section class="ea-success">
    <Container>
      <div class="ea-success-inner">
        <p class="ea-success-label">Order confirmed</p>
        <h1 class="ea-success-title">You're in — we'll get started on your ads.</h1>
        <p class="ea-success-copy">
          Payment confirmed. Fill out your creative brief so we can concept, design, and deliver your
          statics in under 24 hours.
        </p>
        <a class="ea-success-btn" href="/brief/">Fill out your brief</a>
      </div>
    </Container>
  </section>
</PageLayout>

<style>
  .ea-success {
    padding: 6rem 0 8rem;
    background: var(--brand-cream);
  }

  .ea-success-inner {
    max-width: 36rem;
    margin: 0 auto;
    text-align: center;
  }

  .ea-success-label {
    margin: 0 0 0.75rem;
    font-family: var(--ea-font-display);
    font-size: 0.875rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--brand-red);
  }

  .ea-success-title {
    margin: 0 0 1rem;
    font-family: var(--ea-font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--brand-ink);
  }

  .ea-success-copy {
    margin: 0 0 2rem;
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--brand-muted);
  }

  .ea-success-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
    border-radius: 999px;
    background: var(--brand-yellow);
    color: var(--brand-ink);
    font-family: var(--ea-font-sans);
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
  }
</style>
