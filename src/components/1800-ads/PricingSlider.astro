---
import {
  ADS_MIN,
  ADS_MAX,
  ADS_DEFAULT,
  ADS_OPTIONS,
  DELIVERY_SCHEDULES,
  getOrderSummary,
  getAdCountIndex,
  formatUsd,
} from '../../data/1800-ads-pricing'

const initial = getOrderSummary(ADS_DEFAULT)
const initialIndex = getAdCountIndex(ADS_DEFAULT)
---

<div class="ea-pricing-card" data-ea-pricing-root>
  <div class="ea-pricing-slider-wrap">
    <div class="ea-pricing-slider-heading">
      <label class="ea-pricing-slider-label" for="ea-ads-slider">How many static ads?</label>
      <span class="ea-pricing-popular" data-ea-popular>Most popular</span>
    </div>
    <div class="ea-pricing-slider-meta">
      <span>{ADS_MIN}</span>
      <span>{ADS_MAX}</span>
    </div>
    <input
      id="ea-ads-slider"
      class="ea-pricing-slider"
      type="range"
      min={0}
      max={ADS_OPTIONS.length - 1}
      step={1}
      value={initialIndex}
      aria-valuemin={ADS_MIN}
      aria-valuemax={ADS_MAX}
      aria-valuenow={initial.adCount}
      aria-valuetext={`${initial.adCount} static ads, ${formatUsd(initial.total)} total`}
      data-ea-slider
    />
    <div class="ea-pricing-slider-ticks" aria-hidden="true">
      {ADS_OPTIONS.map((count) => (
        <span>{count}</span>
      ))}
    </div>
  </div>

  <div class="ea-pricing-summary">
    <div class="ea-pricing-count-block">
      <span class="ea-pricing-quantity-value" data-ea-count aria-live="polite">{initial.adCount}</span>
      <span class="ea-pricing-quantity-label">static ads</span>
    </div>
    <div class="ea-pricing-price-block">
      <div class="ea-pricing-total" data-ea-total>{formatUsd(initial.total)}</div>
      <div class="ea-pricing-per">
        <span data-ea-per-ad>{formatUsd(initial.pricePerAd)}</span> per ad
      </div>
      <div
        class="ea-pricing-savings"
        data-ea-savings
        hidden={initial.savings <= 0}
      >
        Save <span data-ea-savings-amount>{formatUsd(initial.savings)}</span>
      </div>
    </div>
  </div>

  <div class="ea-pricing-extras" data-ea-extras>
    <fieldset class="ea-pricing-delivery">
      <legend class="ea-pricing-delivery-label">Delivery schedule</legend>
      <div class="ea-pricing-delivery-options" role="radiogroup" aria-label="Delivery schedule">
        {
          DELIVERY_SCHEDULES.map((option) => (
            <button
              type="button"
              class:list={[
                'ea-pricing-delivery-option',
                { 'is-active': option.id === 'one-time' },
              ]}
              data-ea-delivery={option.id}
              aria-pressed={option.id === 'one-time'}
            >
              <span class="ea-pricing-delivery-option-label">{option.label}</span>
              <span class="ea-pricing-delivery-option-desc">{option.description}</span>
            </button>
          ))
        }
      </div>
    </fieldset>
  </div>

  <button
    type="button"
    class="ea-pricing-cta"
    data-ea-checkout
    aria-label={`Order ${initial.adCount} ads for ${formatUsd(initial.total)}`}
  >
    <span class="ea-pricing-cta-desktop">
      Order <span data-ea-cta-count>{initial.adCount}</span> ads — <span data-ea-cta-total
        >{formatUsd(initial.total)}</span
      >
    </span>
    <span class="ea-pricing-cta-mobile">Get started now</span>
    <svg
      class="ea-pricing-cta-icon"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="m9 18 6-6-6-6"></path>
    </svg>
  </button>
  <p class="ea-pricing-note" data-ea-note>One-time payment · Brief sent after checkout</p>
</div>

<script>
  import {
    getAdCountFromIndex,
    getAdCountIndex,
    getOrderSummary,
    formatUsd,
    type DeliverySchedule,
  } from '../../data/1800-ads-pricing'

  function initPricingSlider() {
    const root = document.querySelector('[data-ea-pricing-root]')
    if (!root) return
    if (root.hasAttribute('data-ea-initialized')) return
    root.setAttribute('data-ea-initialized', '')

    const slider = root.querySelector('[data-ea-slider]')
    const countEl = root.querySelector('[data-ea-count]')
    const totalEl = root.querySelector('[data-ea-total]')
    const perAdEl = root.querySelector('[data-ea-per-ad]')
    const savingsEl = root.querySelector('[data-ea-savings]')
    const savingsAmountEl = root.querySelector('[data-ea-savings-amount]')
    const ctaCountEl = root.querySelector('[data-ea-cta-count]')
    const ctaTotalEl = root.querySelector('[data-ea-cta-total]')
    const checkoutBtn = root.querySelector('[data-ea-checkout]')
    const extrasEl = root.querySelector('[data-ea-extras]')
    const noteEl = root.querySelector('[data-ea-note]')
    const deliveryButtons = root.querySelectorAll('[data-ea-delivery]')
    const popularEl = root.querySelector('[data-ea-popular]')

    if (!(slider instanceof HTMLInputElement)) return

    let currentCount = getAdCountFromIndex(Number(slider.value))
    let currentDelivery: DeliverySchedule = 'one-time'

    const updateNote = () => {
      if (!noteEl) return
      if (currentDelivery === 'one-time') {
        noteEl.textContent = 'One-time payment · Brief sent after checkout'
        return
      }
      noteEl.textContent = 'Monthly delivery · Brief sent after checkout'
    }

    const updateDeliveryUI = () => {
      deliveryButtons.forEach((btn) => {
        const schedule = btn.getAttribute('data-ea-delivery') as DeliverySchedule
        const active = schedule === currentDelivery
        btn.classList.toggle('is-active', active)
        btn.setAttribute('aria-pressed', String(active))
      })
      updateNote()
    }

    const updateUI = (index: number) => {
      currentCount = getAdCountFromIndex(index)
      const order = getOrderSummary(currentCount)

      slider.value = String(getAdCountIndex(order.adCount))
      slider.setAttribute('aria-valuenow', String(order.adCount))
      slider.setAttribute(
        'aria-valuetext',
        `${order.adCount} static ads, ${formatUsd(order.total)} total`,
      )

      if (countEl) countEl.textContent = String(order.adCount)
      if (totalEl) totalEl.textContent = formatUsd(order.total)
      if (perAdEl) perAdEl.textContent = formatUsd(order.pricePerAd)
      if (ctaCountEl) ctaCountEl.textContent = String(order.adCount)
      if (ctaTotalEl) ctaTotalEl.textContent = formatUsd(order.total)
      if (popularEl) popularEl.toggleAttribute('hidden', order.adCount !== 10)
      checkoutBtn?.setAttribute(
        'aria-label',
        `Order ${order.adCount} ads for ${formatUsd(order.total)}`,
      )

      if (savingsEl && savingsAmountEl) {
        if (order.savings > 0) {
          savingsEl.removeAttribute('hidden')
          savingsAmountEl.textContent = formatUsd(order.savings)
        } else {
          savingsEl.setAttribute('hidden', '')
        }
      }

      if (extrasEl) extrasEl.removeAttribute('hidden')

      updateDeliveryUI()
    }

    slider.addEventListener('input', () => {
      updateUI(Number(slider.value))
    })

    const openCheckoutFlow = () => {
      try {
        const w = window as Window & { dataLayer?: Record<string, unknown>[] }
        const order = getOrderSummary(currentCount)
        w.dataLayer = w.dataLayer || []
        w.dataLayer.push({ ecommerce: null })
        w.dataLayer.push({
          event: 'add_to_cart',
          ecommerce: {
            currency: 'USD',
            value: order.total,
            items: [
              {
                item_id: `1800-ads-${order.adCount}`,
                item_name: `1-800 Ads — ${order.label}`,
                item_brand: '1-800 Ads',
                item_category: '1800_ads',
                price: order.total,
                quantity: 1,
              },
            ],
          },
        })
      } catch {
        /* ignore */
      }

      const detail = {
        adCount: currentCount,
        deliverySchedule: currentDelivery,
      }

      const openCheckout = () => {
        document.dispatchEvent(new CustomEvent('open-1800-checkout', { detail }))
      }

      openCheckout()
    }

    deliveryButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const schedule = btn.getAttribute('data-ea-delivery') as DeliverySchedule
        if (!schedule) return
        currentDelivery = schedule
        updateDeliveryUI()
      })
    })

    checkoutBtn?.addEventListener('click', openCheckoutFlow)

    updateUI(Number(slider.value))
  }

  initPricingSlider()
  document.addEventListener('astro:page-load', initPricingSlider)
</script>

<style>
  .ea-pricing-card {
    height: 100%;
    padding: clamp(2rem, 3.5vw, 2.75rem);
    border: 1px solid #e0e0e6;
    border-radius: 20px;
    background: var(--brand-cream-dark);
  }

  .ea-pricing-slider-wrap {
    margin-bottom: 2rem;
  }

  .ea-pricing-slider-label {
    display: block;
    margin-bottom: 1rem;
    font-family: var(--ea-font-sans);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--brand-ink);
  }

  .ea-pricing-slider-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .ea-pricing-popular {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    padding: 3px 10px;
    border-radius: 999px;
    background: var(--brand-red, #c8102e);
    color: #fff;
    font-family: var(--ea-font-sans, 'Inter', sans-serif);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1;
    text-transform: uppercase;
  }

  .ea-pricing-popular[hidden] {
    display: none;
  }

  @media (max-width: 540px) {
    .ea-pricing-popular {
      display: none;
    }
  }

  .ea-pricing-slider-meta {
    display: flex;
    justify-content: space-between;
    font-family: var(--ea-font-sans);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a8398;
    margin-bottom: 0.5rem;
  }

  .ea-pricing-slider-ticks {
    display: flex;
    justify-content: space-between;
    margin-top: 0.45rem;
    padding: 0 2px;
    font-family: var(--ea-font-sans);
    font-size: 11px;
    color: #8a8398;
  }

  .ea-pricing-slider {
    width: 100%;
    height: 10px;
    appearance: none;
    border-radius: 999px;
    background: var(--brand-white);
    border: 1px solid rgba(42, 8, 16, 0.08);
    cursor: pointer;
  }

  .ea-pricing-slider::-moz-range-track {
    height: 10px;
    border-radius: 999px;
    background: var(--brand-white);
    border: 1px solid rgba(42, 8, 16, 0.08);
  }

  .ea-pricing-slider::-webkit-slider-thumb {
    appearance: none;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 0;
    background: var(--brand-red);
    box-shadow: 0 4px 14px rgba(200, 16, 46, 0.35);
  }

  .ea-pricing-slider::-moz-range-thumb {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 0;
    background: var(--brand-red);
    box-shadow: 0 4px 14px rgba(200, 16, 46, 0.35);
  }

  .ea-pricing-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.75rem;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid var(--brand-line);
  }

  .ea-pricing-count-block {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 0 1 auto;
    min-width: 0;
  }

  .ea-pricing-quantity-value {
    display: block;
    font-family: var(--ea-font-display);
    font-size: clamp(2.75rem, 8vw, 4.25rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--brand-red);
  }

  .ea-pricing-quantity-label {
    font-family: var(--ea-font-sans);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brand-ink);
    white-space: nowrap;
  }

  .ea-pricing-price-block {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.2rem;
    text-align: right;
  }

  .ea-pricing-total {
    font-family: var(--ea-font-display);
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 400;
    letter-spacing: -0.03em;
    color: var(--brand-ink);
    line-height: 1;
    white-space: nowrap;
  }

  .ea-pricing-per {
    font-size: 0.875rem;
    line-height: 1.35;
    color: var(--brand-muted);
    white-space: nowrap;
  }

  .ea-pricing-savings {
    font-family: var(--ea-font-sans);
    font-size: 0.8125rem;
    line-height: 1.35;
    color: var(--brand-red);
    font-weight: 600;
    white-space: nowrap;
  }

  .ea-pricing-savings[hidden] {
    display: none;
  }

  @media (max-width: 540px) {
    .ea-pricing-card {
      padding: 1.5rem 1.15rem;
    }

    .ea-pricing-summary {
      gap: 0.75rem;
      margin-bottom: 1.35rem;
      padding-bottom: 1.35rem;
    }

    .ea-pricing-quantity-value {
      font-size: clamp(2.25rem, 14vw, 2.75rem);
    }

    .ea-pricing-total {
      font-size: clamp(1.5rem, 8vw, 1.875rem);
    }

    .ea-pricing-per,
    .ea-pricing-savings {
      font-size: 0.75rem;
    }
  }

  @media (max-width: 360px) {
    .ea-pricing-summary {
      flex-direction: column;
      align-items: stretch;
      text-align: left;
    }

    .ea-pricing-count-block {
      flex-direction: row;
      align-items: baseline;
      gap: 0.45rem;
    }

    .ea-pricing-price-block {
      align-items: flex-start;
      text-align: left;
      padding-top: 0.35rem;
      border-top: 1px solid var(--brand-line);
    }
  }

  .ea-pricing-extras {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .ea-pricing-extras[hidden] {
    display: none;
  }

  .ea-pricing-delivery {
    margin: 0;
    padding: 0;
    border: 0;
    min-width: 0;
  }

  .ea-pricing-delivery-label {
    display: block;
    margin-bottom: 0.65rem;
    font-family: var(--ea-font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--brand-ink);
  }

  .ea-pricing-delivery-options {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
  }

  @media (max-width: 480px) {
    .ea-pricing-delivery-options {
      grid-template-columns: 1fr;
    }
  }

  .ea-pricing-delivery-option {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
    padding: 0.65rem 0.75rem;
    border-radius: 12px;
    border: 1px solid var(--brand-line);
    background: var(--brand-cream);
    text-align: left;
    cursor: pointer;
    transition:
      border-color 0.15s,
      background 0.15s,
      box-shadow 0.15s;
  }

  .ea-pricing-delivery-option:hover {
    border-color: #c9b8f0;
  }

  .ea-pricing-delivery-option.is-active {
    border-color: var(--brand-red);
    background: rgba(200, 16, 46, 0.08);
    box-shadow: inset 0 0 0 1px rgba(200, 16, 46, 0.15);
  }

  .ea-pricing-delivery-option-label {
    font-family: var(--ea-font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--brand-ink);
  }

  .ea-pricing-delivery-option-desc {
    font-family: var(--ea-font-sans);
    font-size: 0.6875rem;
    color: #8a8398;
  }

  .ea-pricing-cta-mobile {
    display: none;
  }

  .ea-pricing-cta {
    display: inline-flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 54px;
    padding: 0.9rem 1.5rem;
    border: 0;
    border-radius: 999px;
    background: var(--brand-red);
    color: var(--brand-white);
    font-family: var(--ea-font-sans);
    font-size: 1rem;
    font-weight: 600;
    white-space: nowrap;
    cursor: pointer;
    box-shadow: 0 8px 24px -8px rgba(0, 0, 0, 0.3);
    transition:
      transform 0.18s ease,
      filter 0.18s ease;
  }

  @media (max-width: 540px) {
    .ea-pricing-cta {
      min-height: 48px;
      padding: 0.85rem 1.25rem;
      font-size: 0.9375rem;
    }

    .ea-pricing-cta-desktop,
    .ea-pricing-cta-icon {
      display: none;
    }

    .ea-pricing-cta-mobile {
      display: inline;
    }
  }

  .ea-pricing-cta:hover {
    transform: translateY(-1px);
    filter: brightness(1.06);
  }

  .ea-pricing-note {
    margin: 0.75rem 0 0;
    text-align: center;
    font-size: 0.75rem;
    color: #8a8398;
  }
</style>
