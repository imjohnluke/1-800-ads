---
import { FAQ_ITEMS } from '../../data/1800-ads-faq'
---

<section class="ea-faq-section ea-section-light" id="faq" data-nav-theme="cream" aria-labelledby="ea-faq-heading">
  <div class="ea-faq-wrap">
    <div class="ea-faq-header-row">
      <div>
        <span class="ea-faq-eyebrow">Things people ask</span>
        <h2 id="ea-faq-heading" class="ea-faq-title">Frequently asked,<br />honestly answered.</h2>
      </div>
      <div class="ea-faq-header-aside">
        <p class="ea-faq-intro">
          If your question isn’t here, order ads and ask in your brief — we’ll sort it out before we design.
        </p>
      </div>
    </div>

    <div class="ea-faq-items">
      {
        FAQ_ITEMS.map((item) => (
          <div class="ea-faq-item">
            <button type="button" class="ea-faq-q">
              {item.question}
              <span class="ea-faq-plus" aria-hidden="true">+</span>
            </button>
            <div class="ea-faq-a">
              <div class="ea-faq-a-inner">{item.answer}</div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  function initFaqAccordion() {
    document.querySelectorAll('.ea-faq-item').forEach((item) => {
      if (item.hasAttribute('data-ea-faq-bound')) return
      item.setAttribute('data-ea-faq-bound', '')

      const q = item.querySelector('.ea-faq-q')
      const a = item.querySelector('.ea-faq-a') as HTMLElement | null

      q?.addEventListener('click', () => {
        const isOpen = item.classList.toggle('open')
        if (a) a.style.maxHeight = isOpen ? `${a.scrollHeight}px` : '0px'
      })
    })
  }

  initFaqAccordion()
  document.addEventListener('astro:page-load', initFaqAccordion)
</script>

<style>
  .ea-faq-section {
    --ea-pad: clamp(20px, 3vw, 28px);
    --ea-maxw: 1232px;
    --ea-card-bg: var(--brand-cream-dark);
    --ea-card-border: var(--brand-line);
    background: var(--brand-cream);
    padding: clamp(52px, 7vw, 88px) 0;
    font-family: var(--ea-font-sans);
    color: var(--brand-ink);
  }

  .ea-faq-wrap {
    max-width: var(--ea-maxw);
    margin: 0 auto;
    padding: 0 var(--ea-pad);
  }

  .ea-faq-header-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: end;
    margin-bottom: 40px;
  }

  @media (max-width: 720px) {
    .ea-faq-header-row {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }

  .ea-faq-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--ea-font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ea-accent);
  }

  .ea-faq-eyebrow::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ea-accent);
    flex: 0 0 6px;
  }

  .ea-faq-title {
    margin: 12px 0 0;
    font-family: var(--ea-font-display);
    font-weight: 800;
    font-size: clamp(36px, 4.8vw, 58px);
    line-height: 1.12;
    letter-spacing: -0.06em;
    text-wrap: balance;
    color: var(--ea-ink);
  }

  .ea-faq-header-aside {
    display: flex;
    align-items: center;
  }

  .ea-faq-intro {
    margin: 0;
    font-size: clamp(16px, 1.45vw, 18px);
    line-height: 1.48;
    letter-spacing: -0.02em;
    color: var(--ea-muted);
    max-width: 42rem;
  }

  .ea-faq-items {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ea-faq-item {
    background: var(--ea-card-bg);
    border: 1px solid var(--ea-card-border);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(17, 17, 15, 0.04);
  }

  .ea-faq-q {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 22px clamp(20px, 2.5vw, 28px);
    font-family: var(--ea-font-sans);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.01em;
    text-align: left;
    color: var(--ea-ink);
    background: none;
    border: 0;
    cursor: pointer;
  }

  .ea-faq-q:hover {
    color: var(--ea-accent);
  }

  .ea-faq-plus {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    flex: 0 0 28px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid #d8d0ee;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    line-height: 1;
    font-weight: 300;
    transition:
      transform 0.22s ease,
      background 0.18s ease;
  }

  .ea-faq-item.open .ea-faq-plus {
    transform: rotate(45deg);
    background: var(--ea-ink);
    color: #fff;
    border-color: var(--ea-ink);
  }

  .ea-faq-a {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .ea-faq-a-inner {
    padding: 0 clamp(20px, 2.5vw, 28px) 22px;
    font-size: 15px;
    line-height: 1.65;
    color: var(--ea-muted);
  }
</style>
