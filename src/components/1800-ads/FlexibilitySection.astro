---
import { FLEXIBILITY_POINTS } from '../../data/1800-ads-flexibility'
---

<section class="ea-flex-section ea-section-light" id="flexibility" data-nav-theme="cream" aria-labelledby="ea-flex-heading" data-ea-flex-section>
  <div class="ea-flex-wrap">
    <div class="ea-flex-header" data-ea-flex-header>
      <h2 id="ea-flex-heading" class="ea-flex-title">
        No big retainer, just good ads whenever you need them.
      </h2>
    </div>

    <ul class="ea-flex-grid" data-ea-flex-grid>
      {
        FLEXIBILITY_POINTS.map((point, index) => (
          <li class="ea-flex-card" data-ea-flex-card style={`--i: ${index}`}>
            <div class="ea-flex-graphic" aria-hidden="true">
              {
                point.icon === 'order' && (
                  <div class="ea-flex-visual ea-flex-visual-order">
                    <div class="ea-flex-msg">
                      <div class="ea-flex-msg-head">
                        <span class="ea-flex-msg-avatar">B</span>
                        <span class="ea-flex-msg-from">Boss</span>
                      </div>
                      <div class="ea-flex-msg-bubble">we need ads in 2 days. Figure it out!</div>
                    </div>
                  </div>
                )
              }
              {
                point.icon === 'cadence' && (
                  <div class="ea-flex-visual ea-flex-visual-cadence">
                    <div class="ea-flex-pills">
                      <span>One-time</span>
                      <span class="is-on">Monthly</span>
                    </div>
                  </div>
                )
              }
              {
                point.icon === 'retainer' && (
                  <div class="ea-flex-visual ea-flex-visual-retainer">
                    <div class="ea-flex-pay-card">
                      <span class="ea-flex-pay-label">This order</span>
                      <span class="ea-flex-pay-amount">Pay once</span>
                    </div>
                    <div class="ea-flex-pay-monthly">
                      <span>Monthly retainer</span>
                    </div>
                  </div>
                )
              }
            </div>
            <h3 class="ea-flex-card-title">{point.title}</h3>
            <p class="ea-flex-card-desc">{point.description}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<script>
  function initFlexReveal() {
    const section = document.querySelector('[data-ea-flex-section]')
    if (!section || section.hasAttribute('data-ea-flex-init')) return
    section.setAttribute('data-ea-flex-init', '')

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (prefersReducedMotion) {
      section.classList.add('is-revealed')
      return
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return
          section.classList.add('is-revealed')
          observer.disconnect()
        })
      },
      { threshold: 0.12, rootMargin: '10% 0px -8% 0px' },
    )

    observer.observe(section)
  }

  initFlexReveal()
  document.addEventListener('astro:page-load', initFlexReveal)
</script>

<style>
  .ea-flex-section {
    --ea-ink: var(--brand-ink);
    --ea-muted: var(--brand-muted);
    --ea-accent: var(--brand-red);
    --ea-card-bg: var(--brand-cream-dark);
    --ea-card-border: #e0e0e6;
    --ea-pad: clamp(20px, 3vw, 28px);
    --ea-maxw: 1232px;

    padding: clamp(104px, 13vw, 152px) 0 clamp(104px, 13vw, 160px);
    background: var(--brand-cream);
    font-family: var(--ea-font-sans);
    color: var(--ea-ink);
  }

  .ea-flex-wrap {
    max-width: var(--ea-maxw);
    margin: 0 auto;
    padding: 0 var(--ea-pad);
  }

  .ea-flex-header {
    max-width: 52rem;
    margin: 0 auto clamp(28px, 4vw, 40px);
    text-align: center;
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 0.75s ease,
      transform 0.75s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .ea-flex-section.is-revealed .ea-flex-header {
    opacity: 1;
    transform: translateY(0);
  }

  .ea-flex-title {
    margin: 0;
    font-family: var(--ea-font-display);
    font-weight: 800;
    font-size: clamp(32px, 4.8vw, 52px);
    line-height: 1.02;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .ea-flex-title-grad {
    color: var(--brand-red);
    -webkit-text-fill-color: var(--brand-red);
  }

  .ea-flex-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    max-width: 960px;
    margin-inline: auto;
  }

  .ea-flex-card {
    background: var(--ea-card-bg);
    border: 1px solid var(--ea-card-border);
    border-radius: 18px;
    padding: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(17, 17, 15, 0.04);
    opacity: 0;
    transform: translateY(22px);
    transition:
      opacity 0.7s ease,
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: calc(0.38s + var(--i, 0) * 0.12s);
  }

  .ea-flex-section.is-revealed .ea-flex-card {
    opacity: 1;
    transform: translateY(0);
  }

  .ea-flex-graphic {
    height: 132px;
    background: linear-gradient(180deg, #faf9fc 0%, var(--brand-cream-dark) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 18px 16px 14px;
    box-sizing: border-box;
  }

  .ea-flex-visual {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  /* ── Order anytime ── */
  .ea-flex-visual-order {
    width: 100%;
  }

  .ea-flex-msg {
    width: min(100%, 240px);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ea-flex-msg-head {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ea-flex-msg-avatar {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: linear-gradient(135deg, #ff8a3d, var(--brand-red));
    color: #fff;
    font-size: 10px;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ea-flex-msg-from {
    font-size: 11px;
    font-weight: 700;
    color: var(--ea-muted);
    letter-spacing: -0.01em;
  }

  .ea-flex-msg-bubble {
    align-self: flex-start;
    max-width: 100%;
    padding: 10px 12px;
    border-radius: 16px 16px 16px 4px;
    background: var(--brand-cream);
    border: 1px solid #e4e4ea;
    box-shadow: 0 4px 14px rgba(17, 17, 15, 0.06);
    font-size: 13px;
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: -0.015em;
    color: var(--ea-ink);
  }

  /* ── Cadence ── */
  .ea-flex-visual-cadence {
    flex-direction: column;
  }

  .ea-flex-pills {
    display: flex;
    gap: 6px;
    flex-wrap: nowrap;
    justify-content: center;
  }

  .ea-flex-pills span {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: -0.01em;
    padding: 8px 11px;
    border-radius: 999px;
    background: var(--brand-cream);
    border: 1px solid #e4e4ea;
    color: var(--ea-muted);
    box-shadow: 0 3px 10px rgba(17, 17, 15, 0.05);
    white-space: nowrap;
  }

  .ea-flex-pills span.is-on {
    background: rgba(123, 63, 228, 0.1);
    border-color: rgba(123, 63, 228, 0.22);
    color: var(--brand-red);
    box-shadow: 0 4px 12px rgba(123, 63, 228, 0.14);
  }

  /* ── No retainers ── */
  .ea-flex-visual-retainer {
    flex-direction: column;
    gap: 8px;
  }

  .ea-flex-pay-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    min-width: 148px;
    padding: 12px 14px;
    border-radius: 12px;
    background: var(--brand-cream);
    border: 1px solid #e4e4ea;
    box-shadow: 0 6px 16px rgba(17, 17, 15, 0.06);
  }

  .ea-flex-pay-label {
    font-family: var(--ea-font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ea-muted);
  }

  .ea-flex-pay-amount {
    font-family: var(--ea-font-display);
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--brand-red);
  }

  .ea-flex-pay-monthly {
    position: relative;
    padding: 6px 12px;
    border-radius: 999px;
    background: var(--brand-cream);
    border: 1px solid #e4e4ea;
    color: #a8a3b3;
    font-size: 11px;
    font-weight: 600;
  }

  .ea-flex-pay-monthly::after {
    content: '';
    position: absolute;
    left: 10px;
    right: 10px;
    top: 50%;
    height: 1.5px;
    background: var(--brand-red-dark);
    transform: rotate(-8deg);
    border-radius: 999px;
  }

  .ea-flex-card-title {
    margin: 0;
    padding: 18px 20px 0;
    font-family: var(--ea-font-display);
    font-weight: 700;
    font-size: clamp(17px, 1.6vw, 19px);
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--ea-ink);
  }

  .ea-flex-card-desc {
    margin: 0;
    padding: 8px 20px 22px;
    font-size: 14px;
    line-height: 1.55;
    color: var(--ea-muted);
  }

  @media (max-width: 820px) {
    .ea-flex-grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .ea-flex-card {
      align-items: stretch;
      text-align: center;
    }

    .ea-flex-card-title,
    .ea-flex-card-desc {
      padding-left: 18px;
      padding-right: 18px;
    }

    .ea-flex-visual-cadence,
    .ea-flex-pills {
      width: 100%;
    }

    .ea-flex-pills {
      gap: 8px;
    }

    .ea-flex-pills span {
      flex: 1 1 0;
      min-width: 0;
      text-align: center;
      font-size: 13px;
      padding: 11px 8px;
    }

    .ea-flex-pay-card {
      align-items: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ea-flex-header,
    .ea-flex-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
