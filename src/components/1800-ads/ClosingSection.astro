---
import { CLOSING_PILLARS } from '../../data/1800-ads-closing'

const designThumbs = [
  '/images/1-800-ads/ad-1.png',
  '/images/1-800-ads/ad-2.png',
  '/images/1-800-ads/ad-3.png',
  '/images/1-800-ads/ad-4.png',
]

const angleNotes = [
  { text: 'What if it actually works?', rotate: -8, y: '18%', color: '#fff3b0', pos: 'top-left' },
  { text: 'Stop overpaying for [category]', rotate: 3, y: '2%', color: '#ffd6e8', pos: 'top-center' },
  { text: '20% off — this weekend only', rotate: 6, y: '18%', color: '#e8d8ff', pos: 'top-right' },
  { text: '47k+ customers can\u2019t be wrong', rotate: -6, y: '58%', color: '#ffe0cc', pos: 'bottom-left' },
  { text: 'The upgrade your routine needs', rotate: 2, y: '82%', color: '#d4f0ff', pos: 'bottom-center' },
  { text: 'Problem \u2192 solution in 3 sec', rotate: 5, y: '58%', color: '#fff3b0', pos: 'bottom-right' },
]
---

<section class="ea-close-section" id="why" aria-labelledby="ea-close-heading">
  <div class="ea-close-wrap">
    <div class="ea-close-header">
      <span class="ea-close-eyebrow">Why 1-800 Ads</span>
      <h2 id="ea-close-heading" class="ea-close-title">
        All the creative you need.<br />
        <span class="ea-close-title-grad">None of the lock-in.</span>
      </h2>
    </div>

    <ul class="ea-close-bento">
      {
        CLOSING_PILLARS.map((pillar) => (
          <li class:list={['ea-close-card', `ea-close-card--${pillar.bento}`]}>
            <div class="ea-close-card-copy">
              <h3 class="ea-close-card-title">{pillar.title}</h3>
              <p class="ea-close-card-desc">{pillar.description}</p>
            </div>

            <div class="ea-close-graphic" aria-hidden="true">
              {
                pillar.icon === 'angles' && (
                  <div class="ea-close-visual ea-close-visual-angles">
                    <div class="ea-close-idea-wall">
                      <div class="ea-close-idea-grid" />
                      <div class="ea-close-idea-center">
                        <span class="ea-close-idea-spark" />
                        <span>New angles</span>
                      </div>
                      {
                        angleNotes.map((note) => (
                          <div
                            class:list={['ea-close-sticky', `ea-close-sticky--${note.pos}`]}
                            style={`--r: ${note.rotate}deg; --y: ${note.y}; --bg: ${note.color}`}
                          >
                            {note.text}
                          </div>
                        ))
                      }
                    </div>
                  </div>
                )
              }
              {
                pillar.icon === 'design' && (
                  <div class="ea-close-visual ea-close-visual-design">
                    <div class="ea-close-ads-peek">
                      {designThumbs.map((src, i) => (
                        <img class={`ea-close-peek-ad ea-close-peek-ad--${i + 1}`} src={src} alt="" loading="lazy" width="160" height="200" />
                      ))}
                    </div>
                  </div>
                )
              }
              {
                pillar.icon === 'speed' && (
                  <div class="ea-close-visual ea-close-visual-speed">
                    <div class="ea-close-inbox">
                      <div class="ea-close-inbox-head">
                        <span class="ea-close-inbox-dot" />
                        <span class="ea-close-inbox-title">New delivery</span>
                        <span class="ea-close-inbox-time">Just now</span>
                      </div>
                      <ul class="ea-close-inbox-files">
                        <li>
                          <span class="ea-close-file-icon ea-close-file-icon--feed" />
                          <div>
                            <span class="ea-close-file-name">feed-1080x1080.png</span>
                            <span class="ea-close-file-meta">Ready for Meta</span>
                          </div>
                        </li>
                        <li>
                          <span class="ea-close-file-icon ea-close-file-icon--story" />
                          <div>
                            <span class="ea-close-file-name">story-1080x1920.png</span>
                            <span class="ea-close-file-meta">Ready for Meta</span>
                          </div>
                        </li>
                      </ul>
                      <div class="ea-close-inbox-footer">
                        <span class="ea-close-inbox-eta">Delivered in &lt; 24 hrs</span>
                      </div>
                    </div>
                  </div>
                )
              }
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .ea-close-section {
    --ea-ink: #11110f;
    --ea-muted: #6b6677;
    --ea-accent: #ff6b2e;
    --ea-grad: linear-gradient(90deg, #ff8a3d 0%, #ff6b2e 22%, #e84b6f 55%, #9c42e0 80%, #7b3fe4 100%);
    --ea-card-bg: #f0f0f3;
    --ea-card-border: #e0e0e6;
    --ea-font-display: 'Inter Tight', 'Plus Jakarta Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    --ea-font-sans: 'Inter', 'DM Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    --ea-pad: clamp(20px, 3vw, 28px);
    --ea-maxw: 1232px;

    padding: clamp(72px, 9vw, 104px) 0 clamp(48px, 6vw, 72px);
    background: #fff;
    font-family: var(--ea-font-sans);
    color: var(--ea-ink);
  }

  .ea-close-wrap {
    max-width: var(--ea-maxw);
    margin: 0 auto;
    padding: 0 var(--ea-pad);
  }

  .ea-close-header {
    max-width: 44rem;
    margin: 0 auto clamp(32px, 4.5vw, 48px);
    text-align: center;
  }

  .ea-close-eyebrow {
    display: inline-block;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ea-accent);
  }

  .ea-close-title {
    margin: 12px 0 0;
    font-family: var(--ea-font-display);
    font-weight: 800;
    font-size: clamp(32px, 4.8vw, 52px);
    line-height: 1.02;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .ea-close-title-grad {
    background: var(--ea-grad);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .ea-close-bento {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
    grid-template-rows: minmax(0, 1fr) minmax(0, 1fr);
    gap: 14px;
    min-height: clamp(480px, 46vw, 580px);
  }

  .ea-close-card {
    background: var(--ea-card-bg);
    border: 1px solid var(--ea-card-border);
    border-radius: 20px;
    padding: clamp(18px, 2.2vw, 24px);
    padding-bottom: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    min-height: 0;
  }

  .ea-close-card--large {
    grid-row: 1 / 3;
    grid-column: 1;
  }

  .ea-close-card--small:nth-child(2) {
    grid-row: 1;
    grid-column: 2;
  }

  .ea-close-card--small:nth-child(3) {
    grid-row: 2;
    grid-column: 2;
  }

  .ea-close-card-copy {
    flex-shrink: 0;
    padding-bottom: 14px;
  }

  .ea-close-card-title {
    margin: 0;
    font-family: var(--ea-font-display);
    font-weight: 700;
    font-size: clamp(18px, 1.65vw, 20px);
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--ea-ink);
  }

  .ea-close-card-desc {
    margin: 6px 0 0;
    font-size: 13px;
    line-height: 1.5;
    color: var(--ea-muted);
  }

  .ea-close-graphic {
    flex: 1;
    min-height: 0;
    margin: 0 calc(-1 * clamp(18px, 2.2vw, 24px));
    margin-top: auto;
    position: relative;
    overflow: hidden;
  }

  .ea-close-visual {
    position: absolute;
    inset: 0;
    width: 100%;
  }

  .ea-close-card--large .ea-close-visual-angles {
    top: 0;
    right: 0;
    left: 0;
    bottom: clamp(10px, 1.2vw, 14px);
  }

  /* ── Angles: brainstorm sticky wall ── */
  .ea-close-visual-angles {
    padding: 0 clamp(14px, 1.8vw, 20px);
    display: flex;
    align-items: stretch;
  }

  .ea-close-idea-wall {
    position: relative;
    width: 100%;
    height: 100%;
    flex: 1;
    background: #fff;
    border: 1px solid #e4e4ea;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(17, 17, 15, 0.06);
  }

  .ea-close-idea-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, #dddde3 1px, transparent 1px);
    background-size: 18px 18px;
    opacity: 0.55;
  }

  .ea-close-idea-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    z-index: 1;
  }

  .ea-close-idea-spark {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--ea-ink);
    box-shadow: 0 4px 14px rgba(17, 17, 15, 0.18);
    position: relative;
  }

  .ea-close-idea-spark::before,
  .ea-close-idea-spark::after {
    content: '';
    position: absolute;
    background: var(--ea-ink);
    border-radius: 2px;
  }

  .ea-close-idea-spark::before {
    width: 3px;
    height: 52px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .ea-close-idea-spark::after {
    width: 52px;
    height: 3px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .ea-close-idea-center span:last-child {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a8398;
  }

  .ea-close-sticky {
    position: absolute;
    top: var(--y);
    width: clamp(124px, 13.5vw, 158px);
    padding: 12px 13px 16px;
    background: var(--bg);
    border-radius: 2px;
    box-shadow:
      0 2px 0 rgba(17, 17, 15, 0.06),
      0 8px 20px rgba(17, 17, 15, 0.1);
    font-family: var(--ea-font-display);
    font-size: clamp(11px, 1.15vw, 14px);
    font-weight: 700;
    line-height: 1.28;
    letter-spacing: -0.02em;
    color: var(--ea-ink);
    text-align: center;
    z-index: 2;
    transform: rotate(var(--r));
  }

  .ea-close-sticky--top-left,
  .ea-close-sticky--bottom-left {
    left: 3%;
  }

  .ea-close-sticky--top-right,
  .ea-close-sticky--bottom-right {
    right: 3%;
    left: auto;
  }

  .ea-close-sticky--top-center,
  .ea-close-sticky--bottom-center {
    left: 50%;
    transform: translateX(-50%) rotate(var(--r));
  }

  .ea-close-sticky::before {
    content: '';
    position: absolute;
    top: -5px;
    left: 50%;
    transform: translateX(-50%);
    width: 12px;
    height: 5px;
    background: rgba(17, 17, 15, 0.08);
    border-radius: 1px;
  }

  /* ── Design: ads peeking from bottom ── */
  .ea-close-visual-design {
    overflow: hidden;
  }

  .ea-close-ads-peek {
    position: absolute;
    inset: 0;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: clamp(4px, 0.6vw, 8px);
    padding: 0 clamp(2px, 0.5vw, 8px);
  }

  .ea-close-peek-ad {
    flex: 1;
    width: 28%;
    max-width: none;
    height: 92%;
    max-height: 100%;
    aspect-ratio: auto;
    object-fit: cover;
    object-position: top center;
    border-radius: 14px 14px 0 0;
    border: 3px solid #fff;
    border-bottom: 0;
    box-shadow: 0 -14px 36px rgba(17, 17, 15, 0.18);
    transform: translateY(14%);
  }

  .ea-close-peek-ad--1 { transform: translateY(18%) rotate(-5deg); }
  .ea-close-peek-ad--2 { transform: translateY(10%) rotate(-1.5deg); }
  .ea-close-peek-ad--3 { transform: translateY(10%) rotate(1.5deg); }
  .ea-close-peek-ad--4 { transform: translateY(18%) rotate(5deg); }

  /* ── Speed: inbox delivery ── */
  .ea-close-visual-speed {
    display: flex;
    flex-direction: column;
    padding: clamp(14px, 1.8vw, 20px) 10px 0;
    box-sizing: border-box;
  }

  .ea-close-inbox {
    width: 100%;
    margin-top: auto;
    background: #fff;
    border: 1px solid #e4e4ea;
    border-bottom: 0;
    border-radius: 14px 14px 0 0;
    box-shadow: 0 -6px 24px rgba(17, 17, 15, 0.06);
    overflow: hidden;
  }

  .ea-close-inbox-head {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-bottom: 1px solid #eeeef2;
    background: #fafafa;
  }

  .ea-close-inbox-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #34c759;
    flex-shrink: 0;
    box-shadow: 0 0 0 3px rgba(52, 199, 89, 0.2);
  }

  .ea-close-inbox-title {
    font-size: 12px;
    font-weight: 700;
    color: var(--ea-ink);
    flex: 1;
  }

  .ea-close-inbox-time {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 9px;
    color: #8a8398;
  }

  .ea-close-inbox-files {
    list-style: none;
    margin: 0;
    padding: 10px 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ea-close-inbox-files li {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: 10px;
    background: #f8f8fa;
    border: 1px solid #ececf0;
  }

  .ea-close-file-icon {
    width: 28px;
    height: 28px;
    border-radius: 7px;
    flex-shrink: 0;
  }

  .ea-close-file-icon--feed {
    background: linear-gradient(135deg, #ff8a3d 0%, #e84b6f 100%);
  }

  .ea-close-file-icon--story {
    background: linear-gradient(135deg, #e84b6f 0%, #7b3fe4 100%);
  }

  .ea-close-inbox-files li div {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }

  .ea-close-file-name {
    font-size: 11px;
    font-weight: 600;
    color: var(--ea-ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ea-close-file-meta {
    font-size: 9px;
    color: #8a8398;
  }

  .ea-close-inbox-footer {
    padding: 8px 14px 12px;
    border-top: 1px solid #eeeef2;
    text-align: right;
  }

  .ea-close-inbox-eta {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #7b3fe4;
  }

  @media (max-width: 820px) {
    .ea-close-bento {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      min-height: 0;
    }

    .ea-close-card--large,
    .ea-close-card--small:nth-child(2),
    .ea-close-card--small:nth-child(3) {
      grid-row: auto;
      grid-column: auto;
    }

    .ea-close-card--large {
      min-height: clamp(400px, 95vw, 480px);
    }

    .ea-close-card--small {
      min-height: clamp(280px, 68vw, 340px);
    }

    .ea-close-sticky {
      width: 96px;
      padding: 8px 8px 10px;
      font-size: 10px;
      line-height: 1.22;
    }

    .ea-close-sticky::before {
      top: -4px;
      width: 10px;
      height: 4px;
    }

    .ea-close-ads-peek {
      display: block;
      padding: clamp(10px, 2.5vw, 16px);
    }

    .ea-close-peek-ad {
      position: absolute;
      flex: none;
      width: 30%;
      min-width: 0;
      height: auto;
      max-height: none;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      object-position: top center;
      border-radius: 12px;
      border: 3px solid #fff;
      box-shadow: 0 10px 28px rgba(17, 17, 15, 0.16);
    }

    .ea-close-peek-ad--1 { left: 4%; top: 22%; transform: rotate(-8deg); }
    .ea-close-peek-ad--2 { left: 30%; top: 6%; transform: rotate(3deg); }
    .ea-close-peek-ad--3 { left: 58%; top: 26%; transform: rotate(-4deg); }
    .ea-close-peek-ad--4 { left: 18%; top: 50%; transform: rotate(6deg); }
  }
</style>
