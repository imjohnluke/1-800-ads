---
import { WORK_EXAMPLES } from '../../data/1800-ads-work'
---

<section class="ea-work-section" id="work" aria-labelledby="ea-work-heading">
  <div class="ea-work-wrap">
    <div class="ea-work-header">
      <span class="ea-work-eyebrow">Examples of work</span>
      <h2 id="ea-work-heading" class="ea-work-title">
        Angles that convert.<br />
        Designs that <span class="ea-work-grad">stand out.</span>
      </h2>
      <p class="ea-work-subtitle">
        A sample of conversion-focused creatives our team has designed and delivered — ready to run on Meta.
      </p>
    </div>

    <ul class="ea-work-grid">
      {
        WORK_EXAMPLES.map((item) => (
          <li class="ea-work-item">
            <figure class="ea-work-card">
              <img src={item.src} alt={item.alt} loading="lazy" width="400" height="500" />
            </figure>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .ea-work-section {
    --ea-bg: #ffffff;
    --ea-ink: #11110f;
    --ea-muted: #6b6677;
    --ea-line: #e2dbf0;
    --ea-accent: #ff6b2e;
    --ea-grad: linear-gradient(90deg, #ff8a3d 0%, #ff6b2e 22%, #e84b6f 55%, #9c42e0 80%, #7b3fe4 100%);
    --ea-font-display: 'Inter Tight', 'Plus Jakarta Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    --ea-font-sans: 'Inter', 'DM Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    --ea-pad: clamp(20px, 3vw, 28px);
    --ea-maxw: 1232px;

    padding: clamp(60px, 8vw, 96px) 0;
    background: var(--ea-bg);
    font-family: var(--ea-font-sans);
    color: var(--ea-ink);
  }

  .ea-work-wrap {
    max-width: var(--ea-maxw);
    margin: 0 auto;
    padding: 0 var(--ea-pad);
  }

  .ea-work-header {
    max-width: 40rem;
    margin: 0 auto clamp(2.5rem, 5vw, 3.5rem);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ea-work-eyebrow {
    display: inline-block;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ea-accent);
  }

  .ea-work-title {
    margin: 12px 0 0;
    font-family: var(--ea-font-display);
    font-weight: 800;
    font-size: clamp(36px, 4.8vw, 56px);
    line-height: 0.93;
    letter-spacing: -0.036em;
    word-spacing: 0.045em;
    text-wrap: balance;
    color: var(--ea-ink);
  }

  .ea-work-grad {
    background: var(--ea-grad);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .ea-work-subtitle {
    margin: 1rem auto 0;
    max-width: 32rem;
    font-size: clamp(16px, 1.45vw, 18px);
    line-height: 1.48;
    letter-spacing: -0.02em;
    color: var(--ea-muted);
  }

  .ea-work-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  @media (min-width: 640px) {
    .ea-work-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }
  }

  @media (min-width: 900px) {
    .ea-work-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1.1rem;
    }
  }

  .ea-work-item {
    min-width: 0;
  }

  .ea-work-card {
    margin: 0;
    aspect-ratio: 4 / 5;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--ea-line);
    background: #fff;
    box-shadow:
      0 4px 16px rgba(17, 24, 39, 0.06),
      0 1px 3px rgba(17, 24, 39, 0.04);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  @media (hover: hover) {
    .ea-work-card:hover {
      transform: translateY(-3px);
      box-shadow:
        0 12px 32px rgba(17, 24, 39, 0.1),
        0 2px 6px rgba(17, 24, 39, 0.05);
    }
  }

  .ea-work-card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
</style>
