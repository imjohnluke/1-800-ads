---
import { WORK_EXAMPLES } from '../../data/1800-ads-work'
---

<section class="ea-work-section ea-section-light" id="work" data-nav-theme="cream" aria-labelledby="ea-work-heading">
  <div class="ea-work-wrap">
    <div class="ea-work-header">
      <h2 id="ea-work-heading" class="ea-work-title">
        Angles that convert.<br />
        Designs that stand out.
      </h2>
      <p class="ea-work-subtitle">
        View samples of our work below.
      </p>
    </div>

    <ul class="ea-work-grid">
      {
        WORK_EXAMPLES.map((item) => (
          <li class="ea-work-item">
            <figure class="ea-work-card">
              <img src={item.src} alt={item.alt} loading="lazy" width="400" height="500" />
            </figure>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .ea-work-section {
    --ea-pad: clamp(20px, 3vw, 28px);
    --ea-maxw: 1232px;

    padding: clamp(60px, 8vw, 96px) 0;
    background: var(--brand-cream);
    font-family: var(--ea-font-sans);
    color: var(--brand-ink);
  }

  .ea-work-wrap {
    max-width: var(--ea-maxw);
    margin: 0 auto;
    padding: 0 var(--ea-pad);
  }

  .ea-work-header {
    max-width: 40rem;
    margin: 0 auto clamp(2.5rem, 5vw, 3.5rem);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ea-work-title {
    margin: 0;
    font-family: var(--ea-font-display);
    font-weight: 400;
    font-size: clamp(36px, 4.8vw, 56px);
    line-height: 1.12;
    letter-spacing: -0.036em;
    word-spacing: 0.045em;
    text-wrap: balance;
    color: var(--brand-ink);
  }

  .ea-work-grad {
    color: var(--brand-red);
    -webkit-text-fill-color: var(--brand-red);
  }

  .ea-work-subtitle {
    margin: 1rem auto 0;
    max-width: 32rem;
    font-size: clamp(16px, 1.45vw, 18px);
    line-height: 1.48;
    letter-spacing: -0.02em;
    color: var(--brand-muted);
  }

  .ea-work-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  @media (min-width: 640px) {
    .ea-work-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }
  }

  @media (min-width: 900px) {
    .ea-work-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1.1rem;
    }
  }

  .ea-work-item {
    min-width: 0;
  }

  .ea-work-card {
    margin: 0;
    aspect-ratio: 4 / 5;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--brand-line);
    background: var(--brand-cream);
    box-shadow:
      0 4px 16px rgba(17, 24, 39, 0.06),
      0 1px 3px rgba(17, 24, 39, 0.04);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  @media (hover: hover) {
    .ea-work-card:hover {
      transform: translateY(-3px);
      box-shadow:
        0 12px 32px rgba(17, 24, 39, 0.1),
        0 2px 6px rgba(17, 24, 39, 0.05);
    }
  }

  .ea-work-card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
</style>
