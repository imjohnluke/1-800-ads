---
import Container from '../ui/Container.astro'

const sectionLinks = [
  { label: 'How it works', href: '#offer' },
  { label: 'Flexibility', href: '#flexibility' },
  { label: 'Examples', href: '#work' },
  { label: 'Pricing', href: '#order' },
  { label: 'Why 1-800 Ads', href: '#why' },
  { label: 'FAQ', href: '#faq' },
]

const policyLinks = [
  { label: 'Privacy policy', href: '/privacy' },
  { label: 'Terms of service', href: '/terms' },
]

const socialLinks = [
  { label: 'Instagram', href: 'https://instagram.com/1800ads' },
  { label: 'LinkedIn', href: 'https://linkedin.com/company/1800ads' },
  { label: 'X', href: 'https://x.com/1800ads' },
]
---

<footer class="ea-footer" data-nav-theme="cream">
  <Container class="ea-footer-inner">
    <div class="ea-footer-grid">
      <div class="ea-footer-brand">
        <img
          src="/images/1-800-ads/logo-black.png?v=4"
          alt="1-800 Ads"
          class="ea-footer-logo"
          width="160"
          height="40"
          loading="lazy"
        />
        <p class="ea-footer-tagline">Static ad creatives on demand — no subscription required.</p>
      </div>

      <div class="ea-footer-col">
        <h4 class="ea-footer-col-title">On this page</h4>
        <nav class="ea-footer-links" aria-label="Page sections">
          {sectionLinks.map((link) => <a href={link.href}>{link.label}</a>)}
        </nav>
      </div>

      <div class="ea-footer-col">
        <h4 class="ea-footer-col-title">Policies</h4>
        <nav class="ea-footer-links" aria-label="Policies">
          {policyLinks.map((link) => <a href={link.href}>{link.label}</a>)}
        </nav>
      </div>

      <div class="ea-footer-col">
        <h4 class="ea-footer-col-title">Social</h4>
        <nav class="ea-footer-links" aria-label="Social">
          {
            socialLinks.map((link) => (
              <a href={link.href} target="_blank" rel="noopener noreferrer">
                {link.label}
              </a>
            ))
          }
        </nav>
      </div>

      <div class="ea-footer-col">
        <h4 class="ea-footer-col-title">Support</h4>
        <nav class="ea-footer-links" aria-label="Customer support">
          <a href="mailto:jl@1-800ads.com">jl@1-800ads.com</a>
        </nav>
      </div>
    </div>
  </Container>
</footer>

<style>
  .ea-footer {
    background: var(--brand-cream);
    padding: clamp(48px, 6vw, 72px) 0 clamp(32px, 4vw, 48px);
    color: var(--brand-ink);
    font-family: var(--ea-font-sans);
    border-top: 1px solid rgba(42, 8, 16, 0.08);
  }

  .ea-footer :global(.ea-footer-inner) {
    max-width: 1232px;
    padding-inline: clamp(20px, 3vw, 28px);
  }

  .ea-footer-grid {
    display: grid;
    grid-template-columns: minmax(260px, 1fr) repeat(4, max-content);
    column-gap: clamp(28px, 3vw, 42px);
    row-gap: 32px;
  }

  .ea-footer-brand {
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: flex-start;
  }

  .ea-footer-logo {
    display: block;
    max-width: none;
    height: 34px;
    width: auto;
    object-fit: contain;
  }

  .ea-footer-tagline {
    margin: 0;
    max-width: 260px;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--brand-muted);
  }

  .ea-footer-col {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .ea-footer-col-title {
    margin: 0;
    font-family: var(--ea-font-display);
    font-size: 0.8125rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--brand-red);
  }

  .ea-footer-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ea-footer-links a {
    color: var(--brand-muted);
    font-size: 0.875rem;
    line-height: 1.4;
    text-decoration: none;
    transition: color 0.2s;
  }

  .ea-footer-links a:hover {
    color: var(--brand-ink);
  }

  @media (max-width: 768px) {
    .ea-footer-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 24px;
      row-gap: 32px;
    }

    .ea-footer-brand {
      grid-column: 1 / -1;
      order: 1;
    }

    .ea-footer-col:nth-child(2) { order: 2; }
    .ea-footer-col:nth-child(4) { order: 3; }
    .ea-footer-col:nth-child(3) { order: 4; }
    .ea-footer-col:nth-child(5) { order: 5; }
  }
</style>
