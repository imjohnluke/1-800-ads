---
import BaseLayout from './BaseLayout.astro'
import Header from '../components/Header.astro'
import PricingCheckout from '../components/1800-ads/PricingCheckout'

interface Props {
  title: string
  description?: string
  image?: string
  canonicalURL?: string
  noIndex?: boolean
}

const { title, description, image, canonicalURL, noIndex } = Astro.props
const stripePublishableKey = import.meta.env.PUBLIC_STRIPE_PUBLISHABLE_KEY ?? ''
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  canonicalURL={canonicalURL}
  noIndex={noIndex}
>
  <slot name="head" slot="head" />
  <Header />
  <main>
    <slot />
  </main>
  <slot name="footer" />
  <script is:inline define:vars={{ stripePublishableKey }}>
    window.__STRIPE_PUBLISHABLE_KEY__ = stripePublishableKey || '';
  </script>
  <PricingCheckout client:load publishableKey={stripePublishableKey} />
</BaseLayout>
